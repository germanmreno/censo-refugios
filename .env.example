# Variables de entorno para el backend
# Copia este archivo a backend/.env y ajusta los valores

# Base de datos PostgreSQL (local)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/censo_refugios?schema=public"

# JWT
JWT_ACCESS_SECRET="cambia-esto-en-produccion-clave-acceso-super-secreta"
JWT_REFRESH_SECRET="cambia-esto-en-produccion-clave-refresh-super-secreta"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# Bootstrap del administrador raíz (usado por el seed script)
ADMIN_CEDULA="V00000000"
ADMIN_NOMBRE="Administrador"
ADMIN_APELLIDO="Raiz"
ADMIN_PASSWORD="CambiaPorUnaClaveSegura123"
